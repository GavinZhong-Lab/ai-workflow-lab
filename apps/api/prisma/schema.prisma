generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ User & Auth ============

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  passwordHash     String?
  name             String?
  avatarUrl        String?
  locale           String    @default("zh-CN")
  theme            String    @default("system")
  isSuperAdmin     Boolean   @default(false)
  emailVerifiedAt  DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  oauthAccounts    UserOAuthAccount[]
  refreshTokens    RefreshToken[]
  orgRoles         UserOrganizationRole[]
  createdOrgs      Organization[]       @relation("OrgCreator")
  readingProgress  UserReadingProgress[]
  favorites        UserFavorite[]

  @@index([email])
}

model UserOAuthAccount {
  id             String   @id @default(uuid())
  userId         String
  provider       String   // google, github
  providerUserId String
  providerEmail  String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============ Organization ============

model Organization {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  logoUrl   String?
  industry  String?
  createdBy String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  creator    User                    @relation("OrgCreator", fields: [createdBy], references: [id])
  members    UserOrganizationRole[]
  roles      Role[]
  invitations Invitation[]
  subscriptions Subscription[]
  payments   Payment[]
}

model UserOrganizationRole {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  roleId         String
  joinedAt       DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])

  @@unique([userId, organizationId])
}

// ============ Invitations ============

model Invitation {
  id             String    @id @default(uuid())
  organizationId String
  email          String
  roleId         String
  token          String    @unique
  invitedBy      String
  status         String    @default("pending") // pending, accepted, cancelled, expired
  expiresAt      DateTime
  createdAt      DateTime  @default(now())
  acceptedAt     DateTime?

  role         Role          @relation(fields: [roleId], references: [id])
  organization Organization  @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([token])
  @@index([email, organizationId])
}

// ============ Permission ============

model Application {
  id          String   @id @default(uuid())
  name        String
  key         String   @unique
  description String?
  iconUrl     String?
  bannerUrl   String?
  isActive    Boolean  @default(true)
  isGeneral   Boolean  @default(false)
  isFeatured  Boolean  @default(false)
  isPaid      Boolean  @default(false)
  industries  Json     @default("[]")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  modules Module[]
}

model Module {
  id            String   @id @default(uuid())
  applicationId String
  name          String
  key           String
  description   String?
  sortOrder     Int      @default(0)

  application Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  permissions Permission[]

  @@unique([applicationId, key])
}

model AppBanner {
  id          String   @id @default(uuid())
  title       String
  description String?
  imageUrl    String
  linkUrl     String?
  linkAppKey  String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Permission {
  id          String @id @default(uuid())
  moduleId    String
  action      String // create, read, update, delete, manage
  description String?

  module      Module          @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]

  @@unique([moduleId, action])
}

model Role {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  isSystem       Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  userOrgRoles   UserOrganizationRole[]
  invitations    Invitation[]

  @@unique([organizationId, name])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ============ Subscription ============

model SubscriptionPlan {
  id                     String   @id @default(uuid())
  name                   String
  billingPeriod          String?  // monthly, yearly, null（Free）
  baseAmountCents        Int      @default(0)
  perPersonAmountCents   Int      @default(0)
  paddleBasePriceId      String?  // Paddle 基础价格 ID，Free 为 null
  paddlePerPersonPriceId String?  // Paddle 人均价格 ID，Free 为 null
  currency               String   @default("cny")
  features               Json     @default("[]")
  sortOrder              Int      @default(0)

  subscriptions Subscription[]
}

model Subscription {
  id                   String    @id @default(uuid())
  organizationId       String
  planId               String
  paddleSubscriptionId String?   // Paddle Subscription ID
  paddleCustomerId     String?   // Paddle Customer ID
  employeeCount        Int       @default(1)
  status               String    @default("active") // active, past_due, canceled, expired, trialing
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  canceledAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id])
  plan         SubscriptionPlan  @relation(fields: [planId], references: [id])
  payments     Payment[]

  @@index([organizationId])
  @@index([paddleSubscriptionId])
}

model Payment {
  id                   String    @id @default(uuid())
  organizationId       String
  subscriptionId       String?
  paddleTransactionId  String?   // Paddle Transaction ID
  paddleInvoiceId      String?   // Paddle Invoice ID
  amountCents          Int
  currency             String    @default("cny")
  paymentMethod        String?   // wechat_pay, alipay, card, paypal
  status               String    @default("succeeded") // succeeded, failed, refunded
  paidAt               DateTime?
  createdAt            DateTime  @default(now())

  organization  Organization  @relation(fields: [organizationId], references: [id])
  subscription  Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([organizationId])
  @@index([paddleTransactionId])
}

// ============ Reader App (XC-AiReader) ============

model Novel {
  id          String   @id @default(uuid())
  title       String
  author      String?
  description String?  @db.Text
  coverUrl    String?
  category    String?
  status      String   @default("SERIAL")     // SERIAL | COMPLETED
  wordCount   Int      @default(0)
  sourceType  String   @default("UPLOAD")     // UPLOAD | SCRAPED
  sourceUrl   String?  @unique                // 爬虫来源URL，用于去重
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chapters         Chapter[]
  favorites        UserFavorite[]
  readingProgress  UserReadingProgress[]
  scraperProgress  ScraperNovelProgress[]

  @@index([category])
  @@index([isActive, sortOrder])
  @@index([sourceType])
  @@map("novels")
}

model Chapter {
  id           String   @id @default(uuid())
  novelId      String
  chapterIndex Int                                  // 章节序号（从1开始）
  title        String
  content      String?  @db.Text                    // 章节正文
  wordCount    Int      @default(0)
  sourceUrl    String?                              // 章节来源URL

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  novel           Novel                    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  readingProgress UserReadingProgress[]

  @@unique([novelId, chapterIndex])
  @@index([novelId])
  @@map("chapters")
}

model UserReadingProgress {
  id         String   @id @default(uuid())
  userId     String
  novelId    String
  chapterId  String
  percentage Float    @default(0)    // 0-100

  updatedAt  DateTime @updatedAt

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  novel      Novel     @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapter    Chapter   @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, novelId])
  @@index([userId])
  @@map("user_reading_progress")
}

model UserFavorite {
  id        String   @id @default(uuid())
  userId    String
  novelId   String

  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([userId, novelId])
  @@index([userId])
  @@map("user_favorites")
}

model ReaderBanner {
  id          String   @id @default(uuid())
  title       String
  imageUrl    String
  linkNovelId String?                              // 关联小说ID
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@map("reader_banners")
}

model ScraperLog {
  id              String    @id @default(uuid())
  siteName        String                               // qidian | zongheng
  status          String    @default("RUNNING")        // RUNNING | COMPLETED | FAILED | STOPPED
  durationHours   Int       @default(1)                // 设定运行时长
  novelCount      Int       @default(0)                // 总采集小说数
  novelCompleted  Int       @default(0)                // 完成数
  novelIncomplete Int       @default(0)                // 未完成数
  chapterCount    Int       @default(0)                // 总采集章节数
  message         String?   @db.Text                   // 日志消息
  detail          Json?                                // 详细数据

  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime  @default(now())

  novelProgresses ScraperNovelProgress[]

  @@index([status])
  @@index([createdAt])
  @@map("scraper_logs")
}

model ScraperNovelProgress {
  id               String   @id @default(uuid())
  scraperLogId     String?                              // 所属爬虫运行记录
  novelId          String?                              // 关联 Novel（创建后回填）
  siteName         String                               // 站点名称
  novelTitle       String                               // 小说名称
  novelUrl         String?                              // 小说来源URL
  author           String?                              // 作者
  totalChapters    Int       @default(0)                // 章节目录总数
  fetchedChapters  Int       @default(0)                // 已采集章节数
  lastChapterIndex Int       @default(0)                // 最后采集的章节序号
  status           String    @default("RUNNING")        // RUNNING | COMPLETED | INCOMPLETE | FAILED
  errorMessage     String?   @db.Text                   // 失败原因

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  novel           Novel?       @relation(fields: [novelId], references: [id], onDelete: SetNull)
  scraperLog      ScraperLog?  @relation(fields: [scraperLogId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([novelId])
  @@index([scraperLogId])
  @@map("scraper_novel_progress")
}

model TranslationConfig {
  id          String   @id @default(uuid())
  provider    String                               // DEEPL | GOOGLE | MICROSOFT
  name        String                               // 显示名称
  apiKey      String                               // API Key（AES加密存储）
  apiEndpoint String?                              // API端点
  priority    Int      @default(0)                 // 优先级（小=高）
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, priority])
  @@map("translation_configs")
}
